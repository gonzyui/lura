{
	"extends": [
		"@sapphire/ts-config",
		"@sapphire/ts-config/extra-strict",
		"@sapphire/ts-config/decorators"
	],
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"tsBuildInfoFile": "dist/.tsbuildinfo",
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"node"
		],
		"strict": true,
		"skipLibCheck": true
	},
	"include": [
		"src"
	]
}